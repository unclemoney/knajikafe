[gd_resource type="Resource" script_class="CatCharacter" load_steps=2 format=3]

[ext_resource type="Script" path="res://Resources/cat_character.gd" id="cat_character"]

[resource]
script = ExtResource("cat_character")
cat_id = "azuki"
cat_name = "Azuki"
personality = "A chubby red-brown cat who runs the kitchen. Loves food vocabulary and taking orders."
specialty_game = "CafeOrders"
unlock_condition = "level:12"
dialogue_lines = PackedStringArray("Order up! What did the customer say?", "The kitchen is my domain, nyaa!", "Ocha? Koohii? Listen carefully!", "I cook, you serve — teamwork!", "Food words are the most delicious to learn!", "Hurry, the customer is waiting!", "That's the wrong order, nyaa! Try again!", "Azuki beans are the best topping~", "Fast service means happy cats!", "Another satisfied customer, nyaa~")
accent_color = Color(0.7, 0.35, 0.3, 1)
cat_number = 6
